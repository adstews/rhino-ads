{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" }
      ]
    }
  ],
  "redirects": [
    { "source": "/solutions/organic-seo", "destination": "/services/seo/", "statusCode": 301 },
    { "source": "/solutions/organic-seo/", "destination": "/services/seo/", "statusCode": 301 },
    { "source": "/solutions/paid-advertising", "destination": "/services/advertising/", "statusCode": 301 },
    { "source": "/solutions/paid-advertising/", "destination": "/services/advertising/", "statusCode": 301 },
    { "source": "/solutions/websites-landing-pages", "destination": "/services/websites/", "statusCode": 301 },
    { "source": "/solutions/websites-landing-pages/", "destination": "/services/websites/", "statusCode": 301 },
    { "source": "/solutions/branding-campaigns", "destination": "/services/branding/", "statusCode": 301 },
    { "source": "/solutions/branding-campaigns/", "destination": "/services/branding/", "statusCode": 301 },
    { "source": "/solutions/video-production", "destination": "/services/video/", "statusCode": 301 },
    { "source": "/solutions/video-production/", "destination": "/services/video/", "statusCode": 301 }
  ]
}
